NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Name of the auth cookie set by the backend (HttpOnly).
# Used by proxy.ts to gate protected routes and by app/layout.tsx
# to seed the initial auth state on the server.
NEXT_PUBLIC_AUTH_COOKIE_NAME=access_token

# Google Identity Services Client ID for "Continue with Google".
# Public by design (visible in page source) — NOT a secret. Must be the SAME
# Client ID the backend has in GOOGLE_CLIENT_ID, or tokens are rejected with
# an audience mismatch (RM-AUTH-017). Also add the prod Vercel origin to the
# GCP "Authorized JavaScript origins" list.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=647525353939-xxxx.apps.googleusercontent.com
